-- Project: FANN
local status = "MATI"

function MenuUtama()
    local pilih = gg.choice({
        "1. AKTIFKAN (Status: "..status..")",
        "2. KELUAR"
    }, nil, "FANN BOMB DETECTOR")

    if pilih == 1 then LogikaBom() end
    if pilih == 2 then os.exit() end
end

function LogikaBom()
    if status == "MATI" then
        status = "AKTIF"
        gg.toast("Mencari Bom...")
        -- Ganti angka di bawah dengan ID asli bom game kamu
        gg.searchNumber("9999", gg.TYPE_DWORD) 
        if gg.getResultCount() == 0 then
            gg.alert("Bom tidak ditemukan. Pastikan ID benar!")
        end
    else
        status = "MATI"
        gg.clearResults()
        gg.toast("Fitur Dimatikan")
    end
end

while true do
    if gg.isVisible() then
        gg.setVisible(false)
        MenuUtama()
    end
end
