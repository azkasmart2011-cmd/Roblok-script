-- Nama Project: FANN
-- Status: Menu Toggle ON/OFF

local featureOn = false -- Status awal fitur (Mati)

function Main()
    local menu = gg.choice({
        (featureOn and "🔴 MATIKAN Deteksi Bom" or "🟢 NYALAKAN Deteksi Bom"),
        "❌ Keluar Script"
    }, nil, "--- FANN SCRIPT MENU ---")

    if menu == 1 then ToggleESP() end
    if menu == 2 then os.exit() end
end

function ToggleESP()
    featureOn = not featureOn -- Membalikkan status (On jadi Off, Off jadi On)
    
    if featureOn then
        gg.toast("ESP Bom: AKTIF")
        -- Memulai loop deteksi di background
        gg.setVisible(false) 
        while featureOn do
            CariBom()
            if gg.isVisible() then break end -- Kembali ke menu jika icon GG diklik
        end
    else
        gg.toast("ESP Bom: NONAKTIF")
    end
end

function CariBom()
    -- Ganti dengan value/ID bom yang sesuai dengan game kamu
    gg.searchNumber("101;202;303", gg.TYPE_DWORD) 
    
    local res = gg.getResults(10)
    if #res > 0 then
        -- Logika penandaan lokasi bom di sini
        gg.toast("⚠ BOM TERDETEKSI!")
    end
    gg.clearResults()
    gg.sleep(1000) -- Jeda 1 detik agar tidak lag/crash
end

-- Menjalankan menu terus menerus
while true do
    if gg.isVisible() then
        Main()
    end
    gg.sleep(100)
end
