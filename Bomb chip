# Project Name: FANN
# Deskripsi: Pendeteksi Objek via Gambar

import time

# Variabel Status
fitur_aktif = False

def cari_bom():
    # Di sini nantinya diisi logika OpenCV untuk scan layar
    # Untuk sekarang, kita gunakan simulasi logika deteksi
    print("[Mencari objek bom di layar...]")
    time.sleep(1)
    # Anggap saja bom ditemukan
    objek_ketemu = True 
    if objek_ketemu:
        print(">> WARNING: BOM MUSUH TERDETEKSI! <<")

def menu():
    global fitur_aktif
    while True:
        print("\n=== FANN BOMB DETECTOR ===")
        print(f"Status: {'[AKTIF]' if fitur_aktif else '[MATI]'}")
        print("1. Nyalakan Deteksi")
        print("2. Matikan Deteksi")
        print("3. Keluar")
        
        pilihan = input("Pilih menu: ")

        if pilihan == '1':
            fitur_aktif = True
            print("Deteksi dijalankan...")
            # Menjalankan deteksi beberapa kali
            for _ in range(5): 
                if not fitur_aktif: break
                cari_bom()
        elif pilihan == '2':
            fitur_aktif = False
            print("Deteksi dimatikan.")
        elif pilihan == '3':
            print("Keluar dari program.")
            break
        else:
            print("Pilihan tidak valid.")

if __name__ == "__main__":
    menu()
